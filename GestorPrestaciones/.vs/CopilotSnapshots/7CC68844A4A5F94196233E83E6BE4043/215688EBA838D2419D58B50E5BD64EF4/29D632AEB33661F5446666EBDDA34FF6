@page
@model GestorPrestacionesWeb.Pages.Clientes.IndexModel
@{
	ViewData["Title"] = "Clientes — Listado";
}

<div class="py-4">
	<h1 class="h3 mb-3 text-dark">Clientes</h1>

	<div class="card shadow-sm">
		<div class="card-body">
			<h2 class="h5 mb-3">Listado de clientes (@Model.Clientes?.Count ?? 0)</h2>

			<form method="post" class="row g-3 align-items-center mb-4">
				<div class="col-auto" style="flex:1;">
					<label for="search" class="visually-hidden">Buscar</label>
					<input type="text" id="search" name="SearchTerm" value="@Model.SearchTerm" class="form-control" placeholder="Nombre, apellidos o DNI" />
				</div>
				<div class="col-auto">
					<button type="submit" class="btn btn-primary">Buscar</button>
					<a asp-page="Clientes/Index" class="btn btn-outline-secondary ms-2">Restablecer</a>
				</div>
			</form>

			@if (Model.Clientes == null || !Model.Clientes.Any())
			{
				<div class="text-muted">No hay clientes.</div>
			}
			else
			{
				<div class="card shadow-sm">
					<div class="card-body">
						<h2 class="h5 mb-3">Resultados (@Model.Clientes.Count)</h2>

						@if (Model.Clientes == null || !Model.Clientes.Any())
						{
							<div class="text-muted">No se encontraron clientes.</div>
						}
						else
						{
							<div class="table-responsive">
								<table class="table table-striped table-hover">
									<thead class="table-light">
										<tr>
											<th>Nombre</th>
											<th>Apellidos</th>
											<th>DNI</th>
											<th>Fecha Nac.</th>
											<th>Género</th>
										</tr>
									</thead>
									<tbody>
										@foreach (var c in Model.Clientes)
										{
											<tr>
												<td>@c.Nombre</td>
												<td>@c.Apellidos</td>
												<td>@c.DNI</td>
												<td>@c.FechaNacimiento.ToString("dd/MM/yyyy")</td>
												<td>@c.Genero</td>
												<td><a asp-page="/Clientes/DetallesCliente" asp-route-id="@c.Id" class="btn btn-sm btn-outline-primary">Ver</a></td>
											</tr>
										}
									</tbody>
								</table>
							</div>
							<script>
								document.addEventListener('click', function (e) {
									var tr = e.target.closest && e.target.closest('tr.client-row');
									if (tr && tr.dataset && tr.dataset.href) {
										window.location.href = tr.dataset.href;
									}
								});
								document.addEventListener('keydown', function (e) {
									if (e.key === 'Enter') {
										var tr = document.activeElement && document.activeElement.closest && document.activeElement.closest('tr.client-row');
										if (tr && tr.dataset && tr.dataset.href) {
											window.location.href = tr.dataset.href;
										}
									}
								});
							</script>
						}
					</div>
				</div>

				<div class="mt-3">
					<a asp-page="Create" class="btn btn-success">Crear cliente</a>
				</div>
			}
		</div>
	</div>
</div>