@page
@model GestorPrestacionesWeb.Pages.Trabajos.IndexModel
@{
	ViewData["Title"] = "Trabajos - Listado";
}

<div class="py-4">
	<h1 class="h3 mb-3 text-dark">Trabajos</h1>

	<div class="card shadow-sm">
		<div class="card-body">
			<h2 class="h5 mb-3">Listado de trabajos</h2>

			@if (Model.Trabajos == null || !Model.Trabajos.Any())
			{
				<div class="text-muted">No hay trabajos.</div>
			}
			else
			{
				<div class="table-responsive">
					<table class="table table-striped table-hover">
						<thead class="table-light">
							<tr>
								<th>Nombre</th>
								<th>Descripcion</th>
								<th>Es de riesgo</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var t in Model.Trabajos)
							{
								<tr>
									<td>@t.Nombre</td>
									<td>@t.Descripcion</td>
									<td align="center">
										@if (t.EsDeRiesgo)
										{
											<span class="badge bg-danger">Sí</span>
										}
										else
										{
											<span class="badge bg-success">No</span>
										}
								</tr>
							}
						</tbody>
					</table>
				</div>

				<div class="mt-3">
					<a asp-page="Create" class="btn btn-success">Crear trabajo</a>
				</div>
			}
		</div>
	</div>
</div>
